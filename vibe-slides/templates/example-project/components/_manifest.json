{
  "version": 1,
  "components": {
    "callout": {
      "file": "callout.js",
      "summary": "Card with a colored left accent bar. Use for side notes and labeled content blocks.",
      "params": {
        "x":       { "type": "number", "required": true,  "description": "left edge, inches" },
        "y":       { "type": "number", "required": true,  "description": "top edge, inches" },
        "w":       { "type": "number", "required": true,  "description": "width, inches" },
        "h":       { "type": "number", "required": true,  "description": "height, inches" },
        "title":   { "type": "string", "required": false, "description": "optional bold header" },
        "body":    { "type": "string", "required": true,  "description": "main text" },
        "variant": { "type": "enum",   "required": false, "default": "info",
                     "options": ["info", "warn", "ok", "muted"],
                     "description": "picks the accent bar color" }
      },
      "preview": "previews/callout.png"
    },

    "arrow": {
      "file": "arrow.js",
      "summary": "Directed arrow between two points.",
      "params": {
        "from":  { "type": "point",  "required": true,  "description": "[x, y] start" },
        "to":    { "type": "point",  "required": true,  "description": "[x, y] end" },
        "style": { "type": "enum",   "required": false, "default": "solid", "options": ["solid", "dashed"] },
        "width": { "type": "number", "required": false, "default": 1.5, "description": "line thickness in pt" },
        "color": { "type": "color",  "required": false, "description": "hex without #; defaults to theme accent" }
      },
      "preview": "previews/arrow.png"
    },

    "stat": {
      "file": "stat.js",
      "summary": "Big number with a small label beneath. Use for headline metrics.",
      "params": {
        "x":      { "type": "number", "required": true },
        "y":      { "type": "number", "required": true },
        "w":      { "type": "number", "required": true },
        "h":      { "type": "number", "required": true },
        "number": { "type": "string", "required": true,  "description": "big text, e.g. '143K'" },
        "label":  { "type": "string", "required": true,  "description": "descriptive caption below" },
        "accent": { "type": "color",  "required": false, "description": "hex without #; defaults to theme accent" }
      },
      "preview": "previews/stat.png"
    },

    "num_circle": {
      "file": "num_circle.js",
      "summary": "Solid circle with a number inside. The deck's recurring motif for steps and markers.",
      "params": {
        "x":         { "type": "number", "required": true },
        "y":         { "type": "number", "required": true },
        "d":         { "type": "number", "required": false, "default": 0.6, "description": "diameter in inches" },
        "n":         { "type": "string", "required": true,  "description": "the number or short text" },
        "color":     { "type": "color",  "required": false },
        "textColor": { "type": "color",  "required": false }
      },
      "preview": "previews/num_circle.png"
    },

    "image_stub": {
      "file": "image_stub.js",
      "summary": "Dashed-outline placeholder for an image that doesn't exist yet. Pair with slide.addNotes() so the full description is stored in speaker notes.",
      "params": {
        "x":           { "type": "number", "required": true },
        "y":           { "type": "number", "required": true },
        "w":           { "type": "number", "required": true },
        "h":           { "type": "number", "required": true },
        "caption":     { "type": "string", "required": false, "description": "short title shown inside the box" },
        "description": { "type": "string", "required": false, "description": "multi-line description; shown truncated inside the box, full text goes to speaker notes" }
      },
      "preview": "previews/image_stub.png"
    }
  }
}
